{
  "expo": {
    "name": "Canopy",
    "slug": "cancer-support-matcher",
    "owner": "city-intelligence-inc",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9F2E7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cityintelligence.cancersupport",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSLocationWhenInUseUsageDescription": "Canopy uses your location to find cancer support resources near you."
      },
      "buildNumber": "25"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F9F2E7"
      },
      "package": "com.cityintelligence.cancersupport",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Canopy uses your location to find cancer support resources near you."
        }
      ],
      "@rnmapbox/maps"
    ],
    "scheme": "cancer-app",
    "extra": {
      "API_URL": "https://iutm2kyhqq.us-east-1.awsapprunner.com",
      "router": {},
      "eas": {
        "projectId": "9aae0a42-c7c7-469e-98ea-a5141fd8ff48"
      }
    }
  }
}
